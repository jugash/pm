{
  "title": "PerfBench — CPU",
  "uid": "perfbench-cpu",
  "tags": ["perfbench", "cpu", "jitter"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "scenario", "type": "query", "label": "Scenario",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values({__name__=~\"perfbench_interruption_ns|perfbench_wakeup_latency_ns\"}, scenario)",
        "includeAll": true, "multi": true, "refresh": 2
      },
      {
        "name": "core", "type": "query", "label": "Core",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(perfbench_interruption_ns{scenario=~\"$scenario\"}, core)",
        "includeAll": true, "multi": true, "refresh": 2
      },
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus" }
    ]
  },
  "panels": [
    { "id": 100, "type": "row", "title": "OS jitter summary (sysjitter)", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "id": 1,
      "type": "bargauge",
      "title": "Per-core jitter p99.9",
      "description": "Isolation health: a clean isolated core should sit well under ~10µs.",
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "max by (scenario, core) (perfbench_interruption_ns{scenario=~\"$scenario\", core=~\"$core\", quantile=\"0.999\"})", "legendFormat": "{{scenario}} core {{core}}", "instant": true }
      ],
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "ns", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 5000 }, { "color": "red", "value": 10000 } ] } } }
    },
    {
      "id": 2,
      "type": "barchart",
      "title": "Interruptions per second by core",
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "max by (core) (perfbench_interruptions_per_sec{scenario=~\"$scenario\", core=~\"$core\"})", "instant": true, "format": "table" }
      ],
      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true } } } ],
      "options": { "xField": "core", "orientation": "vertical", "showValue": "auto", "legend": { "showLegend": false }, "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "unit": "1/s", "decimals": 1 } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Worst time interrupted",
      "description": "Fraction of runtime lost to interruptions on the busiest core.",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "max by (scenario, core) (perfbench_interrupted_percent{scenario=~\"$scenario\", core=~\"$core\"})", "legendFormat": "{{scenario}} core {{core}}", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 4 } }
    },

    { "id": 101, "type": "row", "title": "sysjitter detail", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 } },
    {
      "id": 4,
      "type": "table",
      "title": "Per-core interruption ladder (ns) — colored by magnitude",
      "description": "Core × quantile heatmap-table; cell colour scales with interruption time. The classic sysjitter view.",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "max by (core, quantile) (perfbench_interruption_ns{scenario=~\"$scenario\", core=~\"$core\"})", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns", "valueLabel": "quantile" } },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true }, "renameByName": { "0": "min", "0.5": "median", "0.9": "p90", "0.99": "p99", "0.999": "p99.9", "0.9999": "p99.99", "1": "max" } } }
      ],
      "fieldConfig": { "defaults": { "unit": "ns", "decimals": 0, "color": { "mode": "continuous-GrYlRd" }, "custom": { "cellOptions": { "type": "color-background", "mode": "gradient" }, "align": "center" } }, "overrides": [ { "matcher": { "id": "byName", "options": "core" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "auto" } }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "text" } } ] } ] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Per-core jitter over time (p99.9 / max)",
      "description": "Run-over-run regression tracking per core.",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "max by (scenario, core, quantile) (perfbench_interruption_ns{scenario=~\"$scenario\", core=~\"$core\", quantile=~\"0.999|1\"})", "legendFormat": "{{scenario}} core {{core}} p{{quantile}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ns", "custom": { "drawStyle": "line", "spanNulls": true } } }
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "Worst-core jitter (max) by core",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "max by (core) (perfbench_interruption_ns{scenario=~\"$scenario\", core=~\"$core\", quantile=\"1\"})", "instant": true, "format": "table" }
      ],
      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true } } } ],
      "options": { "xField": "core", "orientation": "vertical", "showValue": "auto", "legend": { "showLegend": false }, "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "unit": "ns", "decimals": 0 } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Time interrupted (%)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "max by (scenario, core) (perfbench_interrupted_percent{scenario=~\"$scenario\", core=~\"$core\"})", "legendFormat": "{{scenario}} core {{core}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },

    { "id": 102, "type": "row", "title": "Scheduler wakeup latency (cyclictest)", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 } },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Wakeup latency min / avg / max per thread",
      "description": "Only present when the cyclictest tool is enabled in the scenario.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "max by (scenario, thread) (perfbench_wakeup_latency_ns{scenario=~\"$scenario\", quantile=\"0\"})", "legendFormat": "{{scenario}} t{{thread}} min" },
        { "expr": "max by (scenario, thread) (perfbench_wakeup_latency_mean_ns{scenario=~\"$scenario\"})", "legendFormat": "{{scenario}} t{{thread}} avg" },
        { "expr": "max by (scenario, thread) (perfbench_wakeup_latency_ns{scenario=~\"$scenario\", quantile=\"1\"})", "legendFormat": "{{scenario}} t{{thread}} max" }
      ],
      "fieldConfig": { "defaults": { "unit": "ns" } }
    },
    {
      "id": 9,
      "type": "barchart",
      "title": "Worst-case wakeup latency (max) by thread",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "max by (thread) (perfbench_wakeup_latency_ns{scenario=~\"$scenario\", quantile=\"1\"})", "instant": true, "format": "table" }
      ],
      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true } } } ],
      "options": { "xField": "thread", "orientation": "vertical", "showValue": "auto", "legend": { "showLegend": false }, "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "unit": "ns", "decimals": 0 } }
    },

    { "id": 103, "type": "row", "title": "Run health", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 } },
    {
      "id": 10,
      "type": "stat",
      "title": "Tool failures (latest)",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "expr": "count(perfbench_tool_ok{scenario=~\"$scenario\"} == 0) OR vector(0)", "instant": true } ],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Last run age",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "expr": "time() - max(perfbench_run_timestamp_seconds{scenario=~\"$scenario\"})", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 86400 }, { "color": "red", "value": 172800 } ] } } }
    },
    {
      "id": 12,
      "type": "table",
      "title": "Run environment (kernel / tuned / isolation)",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "expr": "perfbench_run_info{scenario=~\"$scenario\"}", "instant": true, "format": "table" } ],
      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true, "Value": true, "__name__": true, "job": true, "instance": true } } } ]
    }
  ]
}
