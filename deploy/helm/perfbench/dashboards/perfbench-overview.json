{
  "title": "PerfBench — Overview",
  "uid": "perfbench-overview",
  "tags": ["perfbench", "latency"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "scenario",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(perfbench_latency_ns, scenario)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      },
      {
        "name": "msg_size",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(perfbench_latency_ns{scenario=~\"$scenario\"}, msg_size)",
        "includeAll": true,
        "multi": false,
        "refresh": 2
      },
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "bargauge",
      "title": "p99 latency by scenario (msg_size=$msg_size)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "max by (scenario, network_path, platform, bond) (perfbench_latency_ns{scenario=~\"$scenario\", msg_size=~\"$msg_size\", quantile=\"0.99\"})",
          "legendFormat": "{{scenario}} ({{platform}}/{{network_path}}/bond={{bond}})",
          "instant": true
        }
      ],
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "ns", "decimals": 0 } }
    },
    {
      "id": 2,
      "type": "bargauge",
      "title": "Median (p50) latency by scenario (msg_size=$msg_size)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "max by (scenario, network_path, platform, bond) (perfbench_latency_ns{scenario=~\"$scenario\", msg_size=~\"$msg_size\", quantile=\"0.5\"})",
          "legendFormat": "{{scenario}} ({{platform}}/{{network_path}}/bond={{bond}})",
          "instant": true
        }
      ],
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "ns", "decimals": 0 } }
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Tail jitter (p99.9 − p50) by scenario",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "max by (scenario, network_path, platform) (perfbench_latency_jitter_ns{scenario=~\"$scenario\", msg_size=~\"$msg_size\"})",
          "legendFormat": "{{scenario}} ({{platform}}/{{network_path}})",
          "instant": true
        }
      ],
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "ns", "decimals": 0 } }
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "Worst per-core OS jitter (sysjitter p99.9)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "max by (scenario, core) (perfbench_interruption_ns{scenario=~\"$scenario\", quantile=\"0.999\"})",
          "legendFormat": "{{scenario}} core {{core}}",
          "instant": true
        }
      ],
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "ns", "decimals": 0 } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Tool failures (latest runs)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "count(perfbench_tool_ok{scenario=~\"$scenario\"} == 0) OR vector(0)", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Last run age",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "time() - max(perfbench_run_timestamp_seconds{scenario=~\"$scenario\"})", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Run environment (kernel / onload / tuned)",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "perfbench_run_info{scenario=~\"$scenario\"}", "instant": true, "format": "table" }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true, "__name__": true, "job": true, "instance": true }
          }
        }
      ]
    }
  ]
}
